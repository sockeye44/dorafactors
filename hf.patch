+        triton.Config({"BLOCK_SIZE": 1024, "ROWS_PER_PROGRAM": 1}, num_warps=2),
+        triton.Config({"BLOCK_SIZE": 2048, "ROWS_PER_PROGRAM": 1}, num_warps=8),
